# =============================================================================
# Pulse - Self-hosted Discord Alternative
# Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NOTE: Avoid using $ in passwords — Docker Compose interprets $VAR as variable
# references.  Use \$ to include a literal dollar sign.

# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------
DOMAIN=localhost
PROTOCOL=http
APP_ENV=development

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=pulse
POSTGRES_PASSWORD=change_me_postgres_password
POSTGRES_DB=pulse
# Set to "require" or "verify-full" when connecting to a managed DB with TLS.
# Leave as "disable" for the stock postgres Docker image (no TLS by default).
POSTGRES_SSLMODE=disable

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis_password

# -----------------------------------------------------------------------------
# MinIO (S3-compatible storage)
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=pulse_minio
# MinIO requires user >= 3 chars and password >= 8 chars.
MINIO_ROOT_PASSWORD=change_me_minio_password
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=pulse-uploads
MINIO_USE_SSL=false
# Optional: base public URL for uploaded file links (e.g. https://cdn.example.com).
# When set, stored URLs will be absolute (https://cdn.example.com/bucket/object).
# When empty, relative paths are used (/storage/bucket/object).
MINIO_PUBLIC_URL=

# -----------------------------------------------------------------------------
# JWT / Auth
# -----------------------------------------------------------------------------
JWT_SECRET=change_me_jwt_secret_at_least_32_chars_long
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# -----------------------------------------------------------------------------
# Backend API
# -----------------------------------------------------------------------------
API_PORT=8080
# Use "debug" for development, "info" for production.
API_LOG_LEVEL=debug
# Lower bcrypt cost speeds up dev login; use 12+ in production.
BCRYPT_COST=10
MAX_UPLOAD_SIZE=52428800
RATE_LIMIT_RPS=60
RATE_LIMIT_BURST=120

# Comma-separated list of origins the CORS middleware will reflect.
# Must include the exact scheme + host the browser uses.
# Frontend container is on port 80; Vite dev server is on 5173.
ALLOWED_ORIGINS=http://localhost,http://localhost:5173

# Comma-separated CIDR subnets whose X-Real-IP header the rate limiter trusts.
# The default Docker bridge network for Compose uses 172.16.0.0/12.
TRUSTED_PROXY_CIDRS=172.16.0.0/12

# -----------------------------------------------------------------------------
# LiveKit (WebRTC SFU + built-in STUN/TURN)
# -----------------------------------------------------------------------------
# LIVEKIT_API_KEY must match the key name in livekit.yaml (__LIVEKIT_API_KEY__ placeholder).
# LIVEKIT_API_SECRET must be at least 32 characters.
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=change_me_livekit_secret_at_least_32_chars_long
# Optional: shared secret for ephemeral TURN credentials. Leave empty to disable.
LIVEKIT_TURN_SECRET=
# Domain advertised to clients for TURN.
# Local dev: use 127.0.0.1 or your LAN IP (e.g. 192.168.1.x) for cross-device testing.
# Production: use a resolvable hostname (e.g. turn.pulse.example.com).
LIVEKIT_TURN_DOMAIN=127.0.0.1
# Internal URL used by the Go API server to reach LiveKit via Docker service DNS.
# Use ws://127.0.0.1:7880 only when running the API outside of Docker.
LIVEKIT_WS_URL=ws://livekit:7880

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
# Browser calls the API directly on port 8080 — no proxy layer.
VITE_API_URL=http://localhost:8080/api
# IMPORTANT: VITE_WS_URL must be an ABSOLUTE WebSocket URL (ws:// or wss://).
# Relative paths are not valid WebSocket URLs in browsers.
VITE_WS_URL=ws://localhost:8080/ws
VITE_APP_NAME=Pulse

# Port the frontend container exposes to the host.
FRONTEND_PORT=80

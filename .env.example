# =============================================================================
# Pulse - Self-hosted Discord Alternative
# Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# NOTE: Avoid using $ in passwords — Docker Compose interprets $VAR as variable references

# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------
DOMAIN=0.0.0.0
PROTOCOL=http
APP_ENV=production

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=pulse
POSTGRES_PASSWORD=change_me_postgres_password
POSTGRES_DB=pulse

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis_password

# -----------------------------------------------------------------------------
# MinIO (S3-compatible storage)
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=pulse_minio
MINIO_ROOT_PASSWORD=change_me_minio_password
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=pulse-uploads
MINIO_USE_SSL=false

# -----------------------------------------------------------------------------
# JWT / Auth
# -----------------------------------------------------------------------------
JWT_SECRET=change_me_jwt_secret_at_least_32_chars_long
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# -----------------------------------------------------------------------------
# Backend API
# -----------------------------------------------------------------------------
API_PORT=8080
API_LOG_LEVEL=info
BCRYPT_COST=12
MAX_UPLOAD_SIZE=52428800
RATE_LIMIT_RPS=60
RATE_LIMIT_BURST=120

# -----------------------------------------------------------------------------
# LiveKit (WebRTC SFU + built-in STUN/TURN)
# -----------------------------------------------------------------------------
# LIVEKIT_API_KEY must match the key name in livekit.yaml [keys:]
# LIVEKIT_API_SECRET must match the secret value in livekit.yaml [keys:devkey:]
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=change_me_livekit_secret_at_least_32_chars_long
# LIVEKIT_TURN_SECRET must match turn.secret in livekit.yaml
LIVEKIT_TURN_SECRET=change_me_livekit_turn_secret
# Internal URL used by the Go API server to reach LiveKit (Docker service DNS)
LIVEKIT_URL=ws://livekit:7880
# Browser-facing URL; must be reachable from the end-user's browser
LIVEKIT_WS_URL=ws://127.0.0.1:7880

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
VITE_API_URL=/api
VITE_WS_URL=/ws
VITE_APP_NAME=Pulse

# -----------------------------------------------------------------------------
# Nginx
# -----------------------------------------------------------------------------
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
